# Backend (FastAPI) — copy to backend/.env or set in shell / docker-compose
SECRET_KEY=change-me-in-production-use-long-random-string
DATABASE_URL=sqlite+aiosqlite:///./lumosity.db
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
# Comma-separated browser origins, or * for dev (credentials disabled with *)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Frontend (Vite) — copy to lumosity-app/.env.local
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
VITE_PROXY_API=http://localhost:8000
# Optional: legacy PHP analytics (MySQL); leave unset to use FastAPI only
# VITE_ANALYTICS_API_URL=http://localhost:8080/analytics.php
