{
  "name": "ygy/admin",
  "description": "Admin panel for Ygy Cognitive Enhancement Platform",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-pgsql": "*",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "guzzlehttp/guzzle": "^7.8",
    "firebase/php-jwt": "^6.10",
    "monolog/monolog": "^3.5",
    "phpmailer/phpmailer": "^6.9",
    "league/csv": "^9.14",
    "matthiasmullie/minify": "^1.3",
    "intervention/image": "^3.6",
    "spatie/image-optimizer": "^1.7",
    "symfony/cache": "^7.0",
    "symfony/mailer": "^7.0",
    "doctrine/dbal": "^4.0",
    "ramsey/uuid": "^4.7",
    "nesbot/carbon": "^3.0",
    "predis/predis": "^2.2",
    "league/flysystem": "^3.23"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.8",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "Ygy\\Admin\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}