{
  "name": "ygy/backend-analytics",
  "description": "PHP analytics edge (MySQL-compatible schema) — optional alongside FastAPI",
  "type": "project",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^10.5"
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "analyse": "phpstan analyse --memory-limit=512M",
    "test": "phpunit"
  }
}
